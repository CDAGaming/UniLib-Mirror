{
    "schema_version": 1,
    "quilt_loader": {
      "id": "${mod_id}",
      "group": "com.gitlab.cdagaming",
      "version": "${version}",
      "metadata": {
        "name": "${mod_name}",
        "description": "A common set of Utilities, designed for over 50 versions of Minecraft!",
        "contributors": {
          "CDAGaming": "Owner"
        },
        "contact": {
          "homepage": "https://www.curseforge.com/minecraft/mc-mods/unilib",
          "sources": "https://gitlab.com/CDAGaming/UniLib",
          "issues": "https://gitlab.com/CDAGaming/UniLib/issues"
        },
        "license": "MIT",
        "icon": "logo.png"
      },
      "intermediate_mappings": "net.fabricmc:intermediary",
      "entrypoints": {
        "client_init": "com.gitlab.cdagaming.unilib.quilt.UniLibQuilt"
      },
      "depends": [
        {
          "id": "quilt_loader",
          "versions": "${loader_version_range}"
        },
        {
          "id": "quilted_fabric_api",
          "versions": ">=1.0.0-"
        },
        {
          "id": "minecraft",
          "versions": {
            "all": [
              "${game_version_range_start}",
              "${game_version_range_end}"
            ]
          }
        },
        {
          "id": "java",
          "versions": ">=17"
        }
      ],
      "breaks": [
        {
          "id": "fabric",
          "reason": "This mod uses QSL for its content, please use Quilted Fabric API instead of Fabric API to allow for this.",
          "unless": "quilted_fabric_api"
        }
      ]
    }
  }